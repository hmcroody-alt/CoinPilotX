# Pulse / CoinPilotXAI Inc. environment template
# Copy to .env for local development only. Never commit real credentials.

# Core app
DATABASE_URL=
FLASK_SECRET_KEY=
SECRET_KEY=
SESSION_SECRET=
SESSION_COOKIE_SECURE=1

# Telegram
BOT_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
APP_BASE_URL=https://coinpilotx.app
# Direct/public Stripe links are intentionally not used for Pro checkout.
STRIPE_PRO_LINK=

# Media / video delivery
MEDIA_STORAGE_PROVIDER=r2
R2_PUBLIC_BASE_URL=https://cdn.coinpilotx.app
# Public, no-challenge source URL used only for Mux asset downloads.
# Example: https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
MUX_SOURCE_BASE_URL=
R2_MUX_SOURCE_BASE_URL=

# BTC payments
BTC_PAYMENT_ADDRESS=

# Admin
ADMIN_ANALYTICS_PASSWORD=
ADMIN_DASHBOARD_TOKEN=
ADMIN_BOOTSTRAP_TOKEN=
ADMIN_RESET_OWNER_PASSWORD=false

# SEO, indexing, and analytics
GA_MEASUREMENT_ID=
POSTHOG_KEY=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Transactional email
# Railway should provide BREVO_API_KEY as a private environment variable.
EMAIL_PROVIDER=brevo
BREVO_API_KEY=
BREVO_DEFAULT_LIST_ID=
BREVO_PRO_LIST_ID=
BREVO_TELEGRAM_LIST_ID=
DEFAULT_FROM_EMAIL=noreply@pulsesoc.com
BREVO_SENDER_EMAIL=noreply@pulsesoc.com
BREVO_SENDER_NAME=Pulse
BREVO_EMAIL_ENABLED=true
MAIL_FROM_ADDRESS=noreply@pulsesoc.com
MAIL_FROM_NAME=Pulse
SUPPORT_FROM_ADDRESS=support@pulsesoc.com
SUPPORT_FROM_NAME=PulseSoc Support
SECURITY_FROM_ADDRESS=security@pulsesoc.com
SECURITY_FROM_NAME=PulseSoc Security

# Optional email fallbacks
SENDGRID_API_KEY=
MAILGUN_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CLAUDE_AI_API=
Gemini_AI_API=
DEEPSEEK_AI_API=
GROQ_AI_API=
UNDX_ROUTER_ENABLED=false
UNDX_MULTI_MODEL_MODE=false
UNDX_DEFAULT_AI_PROVIDER=openai

# Market data
COINGECKO_API_KEY=
COINMARKETCAP_API_KEY=
CMC_API_KEY=

# Sports data
THE_ODDS_API_KEY=
SPORTSDATA_API_KEY=

# Brevo SMS notifications
BREVO_SMS_API_KEY=
BREVO_SMS_ENABLED=false
BREVO_SMS_SENDER=Pulse
BREVO_SMS_REPLY_EMAIL=support@pulsesoc.com

# Legacy SMS integrations
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
