# CoinPilotXAI Inc. environment template
# Copy to .env for local development only. Never commit real credentials.

# Core app
DATABASE_URL=
FLASK_SECRET_KEY=
SECRET_KEY=

# Telegram
BOT_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
APP_BASE_URL=https://coinpilotx.app
# Direct/public Stripe links are intentionally not used for Pro checkout.
STRIPE_PRO_LINK=

# BTC payments
BTC_PAYMENT_ADDRESS=

# Admin
ADMIN_ANALYTICS_PASSWORD=
ADMIN_DASHBOARD_TOKEN=
ADMIN_BOOTSTRAP_TOKEN=
ADMIN_RESET_OWNER_PASSWORD=false

# SEO, indexing, and analytics
GA_MEASUREMENT_ID=
POSTHOG_KEY=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Transactional email
# Railway should provide BREVO_API_KEY as a private environment variable.
EMAIL_PROVIDER=brevo
BREVO_API_KEY=
BREVO_DEFAULT_LIST_ID=
BREVO_PRO_LIST_ID=
BREVO_TELEGRAM_LIST_ID=
MAIL_FROM_ADDRESS=support@coinpilotx.app
MAIL_FROM_NAME=CoinPilotXAI Inc.

# Optional email fallbacks
SENDGRID_API_KEY=
MAILGUN_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Market data
COINGECKO_API_KEY=
COINMARKETCAP_API_KEY=
CMC_API_KEY=

# Sports data
THE_ODDS_API_KEY=
SPORTSDATA_API_KEY=

# Future SMS integrations
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
