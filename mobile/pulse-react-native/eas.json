{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_PULSE_API_BASE_URL": "https://pulsesoc.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_PULSE_API_BASE_URL": "https://pulsesoc.com"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_PULSE_API_BASE_URL": "https://pulsesoc.com"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6777591572"
      },
      "android": {
        "serviceAccountKeyPath": "./credentials/google-play-service-account.json"
      }
    }
  }
}
