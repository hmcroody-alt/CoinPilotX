{
  "expo": {
    "name": "PulseSoc",
    "slug": "pulsesoc",
    "scheme": "pulse",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#06111f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pulsesoc.app",
      "googleServicesFile": "./credentials/firebase/GoogleService-Info.plist",
      "associatedDomains": [
        "applinks:pulsesoc.com",
        "applinks:www.pulsesoc.com"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "PulseSoc uses the camera when you choose to capture profile media, videos, reels, statuses, or message attachments.",
        "NSMicrophoneUsageDescription": "PulseSoc uses the microphone when you choose to record videos, reels, statuses, voice notes, or live content.",
        "NSPhotoLibraryUsageDescription": "PulseSoc uses photo library access when you choose media to upload to your profile, posts, messages, videos, reels, or statuses.",
        "NSUserTrackingUsageDescription": "PulseSoc does not require cross-app tracking for core features.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.pulsesoc.app",
      "googleServicesFile": "./credentials/firebase/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06111f"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "pulsesoc.com",
              "pathPrefix": "/pulse"
            },
            {
              "scheme": "https",
              "host": "www.pulsesoc.com",
              "pathPrefix": "/pulse"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#5ee1b7",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://pulsesoc.com",
      "eas": {
        "projectId": "712c1e38-a984-433f-bce1-f517693bd3fb"
      }
    },
    "owner": "hmcroody"
  }
}
