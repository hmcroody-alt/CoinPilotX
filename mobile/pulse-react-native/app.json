{
  "expo": {
    "name": "Pulse",
    "slug": "pulse",
    "scheme": "pulse",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pulsesoc.app"
    },
    "android": {
      "package": "com.pulsesoc.app",
      "adaptiveIcon": {
        "backgroundColor": "#06111f"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "apiBaseUrl": "https://pulsesoc.com",
      "eas": {
        "projectId": ""
      }
    }
  }
}
