{
  "name": "pulse-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eas-build-pre-install": "node scripts/prepare-firebase-config.js",
    "typecheck": "tsc --noEmit",
    "audit": "npm run audit:foundation && npm run audit:authentication && npm run audit:feed && npm run audit:notifications && npm run audit:production-parity && npm run audit:android-ui && npm run audit:mobile-web-parity && npm run audit:mobile-performance && npm run audit:firebase && npm run audit:native-live && npm run audit:store",
    "audit:foundation": "node scripts/foundation-audit.js",
    "audit:authentication": "node scripts/authentication-audit.js",
    "audit:feed": "node scripts/feed-audit.js",
    "audit:notifications": "node scripts/notifications-audit.js",
    "audit:production-parity": "node scripts/production-parity-audit.js",
    "audit:android-ui": "node scripts/android-ui-quality-audit.js",
    "audit:mobile-web-parity": "node scripts/mobile-web-parity-audit.js",
    "audit:mobile-performance": "node scripts/mobile_performance_audit.js",
    "audit:firebase": "node scripts/firebase-audit.js",
    "audit:native-live": "node scripts/native-live-audit.js",
    "audit:store": "cd ../.. && .venv/bin/python scripts/pulse_store_submission_readiness_audit.py"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^14.0.0",
    "@expo/config-plugins": "^55.0.10",
    "@expo/metro-runtime": "~55.0.11",
    "@expo/vector-icons": "^15.1.1",
    "@livekit/react-native": "^2.11.0",
    "@livekit/react-native-expo-plugin": "^1.0.2",
    "@livekit/react-native-webrtc": "^144.1.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "~55.0.0",
    "expo-build-properties": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-device": "~55.0.17",
    "expo-font": "~55.0.8",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "~55.0.15",
    "expo-notifications": "~55.0.23",
    "expo-secure-store": "~55.0.14",
    "expo-video": "~55.0.17",
    "livekit-client": "^2.19.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-vision-camera": "^5.0.11",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.16.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "babel-preset-expo": "~55.0.8",
    "typescript": "~5.9.2"
  }
}
