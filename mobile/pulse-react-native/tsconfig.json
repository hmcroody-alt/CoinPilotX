{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "App.tsx",
    "index.ts",
    "components/**/*.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "navigation/**/*.ts",
    "navigation/**/*.tsx",
    "screens/**/*.ts",
    "screens/**/*.tsx",
    "services/**/*.ts",
    "services/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "store/**/*.ts",
    "store/**/*.tsx",
    "utils/**/*.ts",
    "utils/**/*.tsx"
  ]
}
