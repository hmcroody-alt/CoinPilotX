{
  "expo": {
    "name": "PulseSoc",
    "slug": "pulsesoc",
    "scheme": "pulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#06111f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pulsesoc.app",
      "buildNumber": "27",
      "googleServicesFile": "./credentials/firebase/GoogleService-Info.plist",
      "associatedDomains": [
        "applinks:pulsesoc.com",
        "applinks:www.pulsesoc.com"
      ]
    },
    "android": {
      "package": "com.pulsesoc.app",
      "googleServicesFile": "./credentials/firebase/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06111f"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#5ee1b7",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://pulsesoc.com",
      "eas": {
        "projectId": ""
      }
    }
  }
}
